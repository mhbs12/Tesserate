# Base Sepolia is the recommended testnet target for the Aave faucet flow.
# BASE_SEPOLIA_RPC_URL defaults to https://sepolia.base.org if omitted.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=

# API key used by Hardhat Verify to publish source code on Etherscan.
ETHERSCAN_API_KEY=

# Optional: deployed TestTgtFaucet address and amount used by npm run fund:faucet.
FAUCET_ADDRESS=
FAUCET_FUND_AMOUNT_TGT=100000
