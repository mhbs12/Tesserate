# RPC endpoint used only by Hardhat scripts/deploy.
# Example providers: Alchemy, Infura, QuickNode, Ankr.
SEPOLIA_RPC_URL=

# Private key of the deployer wallet, used only to deploy/configure contracts.
# Never use a wallet with real mainnet funds here. Never commit a filled .env.
SEPOLIA_PRIVATE_KEY=

# API key used by Hardhat Verify to publish source code on Etherscan.
ETHERSCAN_API_KEY=
